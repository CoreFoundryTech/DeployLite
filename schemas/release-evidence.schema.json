{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeployLite release evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["commit", "alphaPosture", "runtime", "inputs", "images", "checks", "exceptions", "smoke", "review", "artifacts"],
  "properties": {
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "alphaPosture": { "const": "alpha-early-access" },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "pnpm", "lockHash"],
      "properties": {
        "node": { "type": "string", "pattern": "^v?24\\.[0-9]+\\.[0-9]+$" },
        "pnpm": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "lockHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "inputs": {
      "type": "object",
      "minProperties": 1,
      "required": ["composeDigest"],
      "properties": {
        "composeDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tag", "digest", "platform", "buildId"],
        "properties": {
          "tag": { "type": "string", "minLength": 1 },
          "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "platform": { "type": "string", "pattern": "^[a-z0-9]+/[a-z0-9]+(?:/[a-z0-9]+)?$" },
          "buildId": { "type": "string", "minLength": 1 }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "result", "command", "artifact", "timestamp"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "result": { "enum": ["pass", "fail", "exception"] },
          "command": { "type": "string", "minLength": 1 },
          "artifact": { "type": "string", "format": "uri-reference", "minLength": 1 },
          "timestamp": { "type": "string", "format": "date-time" },
          "exceptionId": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]*-[0-9]+$" }
        },
        "allOf": [{
          "if": { "properties": { "result": { "const": "exception" } }, "required": ["result"] },
          "then": { "required": ["exceptionId"] }
        }]
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "component", "owner", "rationale", "compensatingControl", "reviewer", "evidence", "expiresAt"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]*-[0-9]+$" },
          "component": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "compensatingControl": { "type": "string", "minLength": 1 },
          "reviewer": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "format": "uri-reference", "minLength": 1 },
          "expiresAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "smoke": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "target"],
      "properties": {
        "status": { "enum": ["pending", "pass", "fail"] },
        "target": { "type": "string", "minLength": 1 }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer", "approvalLocation"],
      "properties": {
        "reviewer": { "type": "string", "minLength": 1 },
        "approvalLocation": { "type": "string", "format": "uri-reference", "minLength": 1 }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "format": "uri-reference", "minLength": 1 }
    }
  },
  "allOf": [{
    "if": {
      "properties": {
        "checks": {
          "contains": {
            "type": "object",
            "properties": { "result": { "const": "exception" } },
            "required": ["result"]
          }
        }
      }
    },
    "then": { "properties": { "exceptions": { "minItems": 1 } } }
  }]
}
