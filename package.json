{
  "name": "deploylite",
  "version": "0.1.0",
  "description": "Lightweight self-hosted deployment control plane for AI-assisted VPS workflows.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "9.15.4"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "check": "pnpm build && pnpm lint && pnpm typecheck && pnpm test",
    "runtime:contract": "bash scripts/runtime-contract.test.sh",
    "ci:evidence:check": "node scripts/ci/collect-evidence.mjs --check-only"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "next": "^15.1.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  }
}
