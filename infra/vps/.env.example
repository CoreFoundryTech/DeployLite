# DeployLite VPS runtime example.
# Copy to a private .env outside source control and replace generated placeholders.
# The future installer will generate secret values once and preserve them on reruns.

COMPOSE_PROJECT_NAME=deploylite

# Public HTTP address for the first VPS runtime slice. No HTTPS, domain, ACME, or Traefik is configured yet.
DEPLOYLITE_PUBLIC_HOST=203.0.113.10
DEPLOYLITE_PUBLIC_WEB_ORIGIN=http://203.0.113.10
DEPLOYLITE_PUBLIC_API_ORIGIN=http://203.0.113.10:3001

# Generated secret placeholder. Do not commit real values.
POSTGRES_PASSWORD=replace-with-generated-secret
DEPLOYLITE_SECRET_KEY=replace-with-at-least-32-random-characters
DEPLOYLITE_AGENT_ID=00000000-0000-4000-8000-000000000001
DEPLOYLITE_AGENT_TOKEN=replace-with-at-least-32-random-characters
# Independent from the bearer token. Rotate by setting PREVIOUS to the old value
# for one successful agent start, then remove PREVIOUS after it has re-signed state.
DEPLOYLITE_AGENT_BUILDER_REGISTRY_INTEGRITY_KEY=replace-with-at-least-32-random-characters
DEPLOYLITE_AGENT_BUILDER_REGISTRY_PREVIOUS_INTEGRITY_KEY=
DEPLOYLITE_AGENT_NAME=DeployLite VPS Agent
DEPLOYLITE_AGENT_ENDPOINT=http://agent:3002
# Comma-separated HTTPS repository hosts. Required for production deployments.
DEPLOYLITE_REPO_ALLOWED_HOSTS=github.com

POSTGRES_DB=deploylite
POSTGRES_USER=deploylite
DEPLOYLITE_SESSION_TTL_SECONDS=28800
DEPLOYLITE_SESSION_COOKIE_NAME=deploylite_session
DEPLOYLITE_SESSION_COOKIE_SECURE=false
DEPLOYLITE_BCRYPT_COST=12
